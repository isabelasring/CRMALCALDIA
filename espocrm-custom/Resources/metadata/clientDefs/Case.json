                "view": "custom:views/case/record/panels/actuo-archivo",
                "notRefreshable": true
            },
            {
                "name": "formatoActuoArchivo",
                "disabled": true
            },
            {
                "name": "activities",
                "disabled": true
            },
            {
                "name": "history",
                "disabled": true
            },
            {
                "name": "tasks",
                "disabled": true
            }
        ],
        "detailSmall": [
            {
                "name": "caseTimeline",
                "label": "Línea de tiempo",
                "view": "custom:views/case/record/panels/status-timeline",
                "notRefreshable": true
            },
            {
                "name": "caseCronograma",
                "label": "Cronograma",
                "view": "custom:views/case/record/panels/case-cronograma",
                "notRefreshable": true
            },
            {
                "name": "caseStream",
                "label": "Flujo",
                "view": "views/stream/panel",
                "notRefreshable": true
            },
            {
                "name": "activities",
                "disabled": true
            },
            {
                "name": "history",
                "disabled": true
            },
            {
                "name": "tasks",
                "disabled": true
            }
        ]
    },
    "fields": {
        "cFormatoSolicitudPdf": {
            "view": "custom:views/case/fields/formato-generado-docs"
        },
        "cPanelActaVisita": {
            "view": "custom:views/case/fields/acta-visita-action"
        },
        "status": {
            "view": "custom:views/case/fields/status"
        },
        "assignedUser": {
            "view": "custom:views/case/fields/assigned-user"
        },
        "cNumeroRadicado": {
            "view": "custom:views/case/fields/numero-radicado"
        },
        "cExpediente": {
            "view": "custom:views/case/fields/expediente"
        },
        "cRecibidaPor": {
            "primaryFilter": "recibidores"
        },
        "cRemitidoA": {
            "primaryFilter": "radicacion"
        },
        "cRadicadoModo": {
            "view": "custom:views/case/fields/enum"
        },
        "cRadicadoSiglas": {
            "view": "custom:views/case/fields/enum"
        },
        "cTipoPersonaPeticionario": {
            "view": "custom:views/case/fields/enum"
        },
        "cBarrio": {
            "view": "custom:views/case/fields/enum"
        },
        "cCanalDeReporte": {
            "view": "custom:views/case/fields/enum"
        },
        "cTipoPersonaPerjudicante": {
            "view": "custom:views/case/fields/enum"
        },
        "cBarrioPerjudicante": {
            "view": "custom:views/case/fields/enum"
        },
        "cRecursoTema": {
            "view": "custom:views/case/fields/enum"
        },
        "cAsunto": {
            "view": "custom:views/case/fields/enum"
        },
        "cZonaAlcaldia": {
            "view": "custom:views/case/fields/enum"
        },
        "cUltimaActuacion": {
            "view": "custom:views/case/fields/enum"
        },
        "cProximaActuacion": {
            "view": "custom:views/case/fields/enum"
        }
    },
    "dynamicLogic": {
        "fields": {
            "assignedUser": {
                "visible": {
                    "conditionGroup": [
                        {
                            "type": "and",
                            "value": [
                                {
                                    "type": "isNotEmpty",
                                    "attribute": "cNumeroRadicado"
                                },
                                {
                                    "type": "isNotEmpty",
                                    "attribute": "cExpediente"
                                }
                            ]
                        }
                    ]
                }
            }
        }
    }
}
