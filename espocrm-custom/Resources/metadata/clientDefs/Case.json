        "contacts": {
            "disabled": true
        },
        "contact": {
            "disabled": true
        },
        "account": {
            "disabled": true
        }
    },
    "sidePanels": {
        "edit": [],
        "detail": [
            {
                "name": "caseTimeline",
                "label": "Línea de tiempo",
                "view": "custom:views/case/record/panels/status-timeline",
                "notRefreshable": true,
                "sticked": true
            },
            {
                "name": "caseCronograma",
                "label": "Cronograma",
                "view": "custom:views/case/record/panels/case-cronograma",
                "notRefreshable": true
            },
            {
                "name": "caseStream",
                "label": "Flujo",
                "view": "views/stream/panel",
                "notRefreshable": true
            },
            {
                "name": "actaVisitaPanel",
                "disabled": true
            },
            {
                "name": "formatoSolicitud",
                "disabled": true
            },
            {
                "name": "formatoActaVisita",
                "disabled": true
            },
            {
                "name": "actuoArchivoPanel",
