{
    "fields": {
        "assignedUser": {
            "view": "custom:views/case/fields/assigned-user",
            "selectPrimaryFilterName": "patrulleros"
        },
        "status": {
            "view": "custom:views/case/fields/status",
            "options": [
                "New",
                "Assigned",
                "Pending",
                "Closed",
                "Rejected",
                "Duplicate",
                "Pendiente de radicacion",
                "Radicado",
                "En proceso",
                "Visita realizada",
                "Visita aprobada",
                "Finalizado",
                "Proceso cerrado"
            ],
            "notActualOptions": [
                "Closed",
                "Rejected",
                "Duplicate"
            ]
        },
        "cNombreDelPeticionario": {
            "type": "varchar",
            "maxLength": 100,
            "isCustom": true
        },
        "cApellido": {
            "type": "varchar",
            "maxLength": 150,
            "isCustom": true
        },
        "cTipoDeDocumento": {
            "type": "enum",
            "options": ["CC", "CE", "NIT", "Pasaporte", "Otro"],
            "default": "CC",
            "maxLength": 100,
            "isCustom": true
        },
        "cNumeroDeDocumento": {
            "type": "varchar",
            "maxLength": 50,
            "isCustom": true
        },
        "cCanalDeReporte": {
            "type": "enum",
            "options": ["Correo", "Teléfono", "Presencial", "WhatsApp", "Página web"],
            "default": "Teléfono",
            "maxLength": 100,
            "isCustom": true
        },
        "cTelefono": {
            "type": "phone",
            "maxLength": 50,
            "isCustom": true
        },
        "cCorreo": {
            "type": "email",
            "maxLength": 100,
            "isCustom": true
        },
        "cMunicipio": {
            "type": "enum",
            "options": ["Envigado"],
            "default": "Envigado",
            "maxLength": 100,
            "isCustom": true
        },
        "cBarrioResidencia": {
            "type": "varchar",
            "maxLength": 150,
            "isCustom": true
        },
        "cDireccion": {
            "type": "text",
            "isCustom": true
        },
        "cNumeroRadicacion": {
            "type": "varchar",
            "maxLength": 100,
            "isCustom": true,
            "tooltip": true,
            "required": false
        },
        "cExpediente": {
            "type": "varchar",
            "maxLength": 50,
            "isCustom": true,
            "readOnly": true,
            "tooltip": true
        },
        "cActaFechaVisita": {
            "type": "date",
            "isCustom": true
        },
        "cActaHoraVisita": {
            "type": "varchar",
            "maxLength": 10,
            "isCustom": true,
            "tooltip": true
        },
        "cActaDireccionVisita": {
            "type": "varchar",
            "maxLength": 255,
            "isCustom": true
        },
        "cActaNombreVisitado": {
            "type": "varchar",
            "maxLength": 150,
            "isCustom": true
        },
        "cActaDocumentoVisitado": {
            "type": "varchar",
            "maxLength": 50,
            "isCustom": true
        },
        "cActaHallazgos": {
            "type": "text",
            "isCustom": true
        },
        "cActaMedidasTomadas": {
            "type": "text",
            "isCustom": true
        },
        "cActaObservaciones": {
            "type": "text",
            "isCustom": true
        },
        "cActaEstado": {
            "type": "enum",
            "options": ["Pendiente", "Diligenciada", "Aprobada"],
            "default": "Pendiente",
            "maxLength": 50,
            "isCustom": true,
            "readOnly": true
        },
        "cActaVistoBueno": {
            "type": "bool",
            "default": false,
            "isCustom": true
        },
        "cActaObservacionesRevision": {
            "type": "text",
            "isCustom": true
        },
        "cActaFechaAprobacion": {
            "type": "date",
            "isCustom": true,
            "readOnly": true
        },
        "cActaRegistroOficial": {
            "type": "bool",
            "default": false,
            "isCustom": true,
            "readOnly": true
        },
        "cCierreFecha": {
            "type": "date",
            "isCustom": true
        },
        "cCierreResumen": {
            "type": "text",
            "isCustom": true
        },
        "cCierreConclusiones": {
            "type": "text",
            "isCustom": true
        },
        "cCierreMedidasAdoptadas": {
            "type": "text",
            "isCustom": true
        },
        "cCierreObservaciones": {
            "type": "text",
            "isCustom": true
        },
        "cCierreEstado": {
            "type": "enum",
            "options": ["Pendiente", "Diligenciado"],
            "default": "Pendiente",
            "maxLength": 50,
            "isCustom": true,
            "readOnly": true
        },
        "cCierreProcesoCompleto": {
            "type": "bool",
            "default": false,
            "isCustom": true,
            "readOnly": true
        },
        "cCierreFechaRegistro": {
            "type": "date",
            "isCustom": true,
            "readOnly": true
        }
    }
}
