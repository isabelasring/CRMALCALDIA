# Copia este archivo a .env y cambia las contraseñas (no subas .env a GitHub)

POSTGRES_DB=espocrm
POSTGRES_USER=espocrm
POSTGRES_PASSWORD=cambiar_db_seguro
POSTGRES_PORT=5433

ESPOCRM_ADMIN_USERNAME=admin
ESPOCRM_ADMIN_PASSWORD=cambiar_admin_seguro
ESPOCRM_SITE_URL=http://localhost:8080
ESPOCRM_TIME_ZONE=America/Bogota
ESPOCRM_WEB_SOCKET_URL=ws://localhost:8081

# Correo saliente (SMTP). Sin esto no llegan emails de asignación.
# Gmail: usa una "Contraseña de aplicación" (no tu contraseña normal).
# https://myaccount.google.com/apppasswords
ESPOCRM_SMTP_SERVER=smtp.gmail.com
ESPOCRM_SMTP_PORT=587
ESPOCRM_SMTP_AUTH=true
ESPOCRM_SMTP_SECURITY=TLS
ESPOCRM_SMTP_USERNAME=tu_correo@gmail.com
ESPOCRM_SMTP_PASSWORD=contraseña_de_aplicacion
ESPOCRM_OUTBOUND_EMAIL_FROM_ADDRESS=tu_correo@gmail.com
ESPOCRM_OUTBOUND_EMAIL_FROM_NAME=CRM Alcaldia
